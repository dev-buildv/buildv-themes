{
  "version": "0.4",
  "title": "Hero Simples",
  "type": "section",
  "content": [
    {
      "id": "placeholder-section",
      "elType": "section",
      "settings": {
        "padding": { "unit": "px", "top": "100", "right": "0", "bottom": "100", "left": "0", "isLinked": false },
        "background_color": "#1a1a2e"
      },
      "elements": [
        {
          "id": "placeholder-col",
          "elType": "column",
          "settings": { "_column_size": 100 },
