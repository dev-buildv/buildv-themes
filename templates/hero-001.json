              "settings": {
                "title": "Título Principal",
                "title_color": "#ffffff",
                "typography_font_size": { "unit": "px", "size": 56 },
                "typography_font_weight": "700",
                "align": "center"
              }
            },
            {
              "id": "placeholder-btn",
              "elType": "widget",
              "widgetType": "button",
              "settings": {
                "text": "Saiba Mais",
                "align": "center",
                "background_color": "#4f46e5",
                "border_radius": { "unit": "px", "top": 6, "right": 6, "bottom": 6, "left": 6 }
              }
            }
          ]
        }
      ]
    }
